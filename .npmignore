*.test.tsx
*.spec.ts
*.spec.tsx

# Build configuration
vite.config.ts
tsconfig.json
tsconfig.node.json
vitest.config.ts
biome.json

# Development files
.gitignore
.npmignore
.npmrc
.eslintrc*
.prettierrc*
.editorconfig

# Documentation (keep README.md and CHANGELOG.md, exclude others)
IMPLEMENTATION.md
EXAMPLES.md
SECURITY.md
REVIEW_SUMMARY.md
REVIEW_COMPLETE.md

# Note: README.md and CHANGELOG.md are intentionally published

