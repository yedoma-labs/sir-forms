{
  "name": "@yedoma-labs/sir-forms",
  "version": "0.2.0",
  "description": "Type-safe React Server Actions form library with progressive enhancement",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "forms",
    "react",
    "server-actions",
    "zod",
    "validation",
    "progressive-enhancement",
    "server-components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yedoma-labs/sir-forms"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "20.11.0",
    "@types/react": "^19.2.16",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "react": "^19.2.7",
    "terser": "^5.48.0",
    "typescript": "6.0.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.0"
  }
}
